<?xml version="1.0" encoding="utf-8"?>
<!-- Vera "V" mark in brand orange. The 100x100 glyph is scaled to ~70% and centered
     inside the 108x108 canvas so it stays within the adaptive safe zone and never
     gets clipped by a round/squircle mask. Reused as the monochrome (themed) layer;
     the system supplies the tint there, so the transparent background is intentional. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="0.70"
        android:scaleY="0.70"
        android:translateX="19"
        android:translateY="19">
        <path
            android:fillColor="#E35400"
            android:pathData="M3,12 L35,12 L54,62 L73,29 L99,29 L99,51 L70,95 Z" />
    </group>
</vector>
